# Sub-flake directories — each is its own independent git repo, cloned
# via `just jj::bootstrap` from repos.nix. NOT tracked as git submodules
# (meta doesn't pin specific commits; deployment uses live local via
# --override-input — see OVERRIDES in .just/common.just).
nix-config/
nix-devshells/
nix-hardware/
nix-packages/
nix-presets/
nix-secrets/
nix-templates/

# Environment State
.direnv/
.devenv/
.tools/
.pre-commit-config.yaml

# Build Results
result
result-*
result_*

# Generated / Runtime State
conversation_history.md
force-rebuild-trigger
.dev-dashboard/cache/
.dev-dashboard/logs/


# Temporary Files
*.bak
*.tar
*.gz
*.tmp
*.log
*.qcow2
cpu_usage.txt
mem_usage.txt

# OS Metadata
.DS_Store

